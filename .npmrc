# Supply-chain hardening (feature 034): wait 7 days before resolving a freshly published version.
# npm is not the install path here (pnpm is; see pnpm-workspace.yaml), but this satisfies the
# npm-minimum-release-age policy for any incidental npm/npx use.
min-release-age = 7

# virtual-store-dir was set here to work around Windows 260-char MAX_PATH in Android
# Gradle/CMake builds, but it breaks Metro module resolution. The APK is built and
# installed separately when this setting is active; revert afterwards for normal dev.
# virtual-store-dir=E:\pnpm-store

# Feature 005 (Expo SDK 56 upgrade) NOTE: tried virtual-store-dir-max-length=40 to
# shorten node_modules/.pnpm/<pkg>@<ver>_<hash>/ dir names and fix the Android CMake
# CMAKE_OBJECT_PATH_MAX (250) overflow on react-native-worklets/-screens C++ builds.
# RESULT: it only trimmed the object DIR 221->201, but CMake replicates the FULL absolute
# source path under the object dir, so the worst object path was still 381 chars — AND
# the shortened store names broke jest/Metro module resolution (all 67 suites failed to
# load), same class of breakage as the relocated-store note above. REVERTED. The reliable
# fix is a short BUILD ROOT (the repo prefix appears ~twice in the object path); see
# specs/005-expo-sdk-56-upgrade/tasks.md T024.

# Feature 005 (Expo SDK 56 upgrade) — Android native build on Windows:
# SDK 56 pulls react-native-worklets (C++, via reanimated 4). Its CMake object paths
# overflow CMAKE_OBJECT_PATH_MAX (250) under the default deep pnpm layout at this repo's
# path. To build the Android APK, do a BUILD-ONLY install with a flat node_modules from a
# short root, then revert:
#   1) mklink /J C:\m "<repo>"   (short build root; the repo prefix appears ~twice in the path)
#   2) add `node-linker=hoisted` here, `cd C:\m && pnpm install` (flat node_modules, no .pnpm hash)
#   3) cd C:\m\frontend\mcm-app && node C:\m\node_modules\expo\bin\cli prebuild --platform android --clean
#   4) cd android && ./gradlew :app:assembleDebug -PreactNativeArchitectures=x86_64
#   5) adb install -r app/build/outputs/apk/debug/app-debug.apk
#   6) REMOVE `node-linker=hoisted`, `pnpm install` again (restores symmetrical layout Metro/jest need)
# Object path: 381 (default) -> 187 (short root + hoisted). Do NOT leave hoisted active — it
# breaks Metro/jest module resolution (all 67 unit suites fail to load).
