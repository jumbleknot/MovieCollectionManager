{
  // .devcontainer/devcontainer.json — feature 037 (containerized dev-env) + 038 (full toolchain)
  // The portable asset (FR-008): must resolve unmodified under BOTH the VS Code Dev
  // Containers extension and @devcontainers/cli. No credential literal (FR-010).
  "name": "mcm-workspace",

  // 038 — host-free, digest-pinned toolchain image (research D2). Top-level `image` is NOT
  // substitution-eligible, but `build.args` IS: the thin Dockerfile does `FROM ${BASE_IMAGE}`,
  // and BASE_IMAGE is fed from ${localEnv:MCM_DEVCONTAINER_IMAGE} (kept in the gitignored local
  // env so the forge HOST never enters git — topology-scrub).
  //
  // ⚠️⚠️ REQUIRED: set MCM_DEVCONTAINER_IMAGE in your host env before opening.
  //   • local build : MCM_DEVCONTAINER_IMAGE=mcm-devcontainer   (colon-free; = the local tag)
  //   • forge fast  : MCM_DEVCONTAINER_IMAGE=<host>/<ns>/mcm-devcontainer@sha256:<digest>
  // The `:mcm-devcontainer` default below is honored ONLY by @devcontainers/cli — the VS Code
  // Dev Containers extension does NOT apply ${localEnv:VAR:default} defaults; when the var is
  // unset it passes `--build-arg BASE_IMAGE=` (EMPTY), which overrides the Dockerfile ARG default
  // and fails with "base name (${BASE_IMAGE}) should not be blank". So under VS Code the env var
  // is mandatory (verified 2026-07-12, extension CLI 0.463.0). See docs/runbooks/devcontainer.md.
  //
  // GOTCHA (also verified): even where the default IS honored (@devcontainers/cli 0.87.0), the
  // ${localEnv:VAR:default} parser truncates the default at its FIRST colon — so the local tag is
  // kept COLON-FREE (`mcm-devcontainer`). A colon-containing ENV value (the `…@sha256:…` digest)
  // passes through intact — only the literal default is affected.
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "BASE_IMAGE": "${localEnv:MCM_DEVCONTAINER_IMAGE:mcm-devcontainer}"
    }
  },

  // FR-004 / US2 — an in-container Docker engine (moby) separate from the host engine, so
  // image builds + compose-based integration tests run without reaching the host engine.
  // HONEST POSTURE (FR-011): enabling this feature makes the resolver run the container
  // `privileged` — a privileged escape can reach the shared Docker Desktop WSL2 VM (moderate
  // engine isolation). Host-FS / credential isolation stays STRONG. Enhanced Container
  // Isolation must stay OFF (incompatible with this feature — research D3). This privileged
  // exception subsumes the US1 capAdd above.
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true
    }
  },

  // FR-002 — never root, never the host user.
  "remoteUser": "coder",

  // NET_ADMIN/NET_RAW let init-firewall.sh program iptables/ipset. (Subsumed once the
  // docker-in-docker feature makes the container privileged — US2/T013 — but kept explicit
  // so US1 is a complete, standalone isolation layer.)
  "capAdd": ["NET_ADMIN", "NET_RAW"],

  // FR-003 — for fast file watching, source SHOULD live on a Docker named volume (Linux-native
  // inside the WSL2 backend), not an NTFS bind mount. That is achieved by opening via VS Code
  // **"Clone Repository in Named Container Volume"** (the daily driver — VS Code creates and
  // clones into the volume itself), NOT by a hardcoded `workspaceMount` here: hardcoding one
  // makes every plain "Reopen in Container" / `devcontainer up` mount an EMPTY volume instead of
  // your working tree. So we omit `workspaceMount` and let the runner bind-mount the opened
  // folder by default; the named-volume speed path is the clone-in-volume command (see runbook).
  // `verify-host-isolation.sh` flags a bind mount so you always know which path you are on.
  //
  // NOTE: `workspaceFolder` is intentionally OMITTED. The runner mounts the opened folder at
  // `/workspaces/<basename>`, where basename is the folder/repo name — `mcm` for a forge
  // clone-in-volume, `MovieCollectionManager` for the local checkout, etc. Hardcoding
  // `workspaceFolder` to a fixed name breaks whenever it differs (postCreate fails with
  // `chdir to cwd ... no such file or directory`, surfaced as exit 127). Omitting it lets the
  // runner default `workspaceFolder` to the actual mount target, so it always matches.

  // Persist shell history + tool caches across rebuilds (Anthropic reference pattern, D4).
  // 038 US2 — persistent DOWNLOAD caches so nothing re-downloads across recreation (FR-004/SC-005).
  // Only dirs that are EMPTY in the image and RUNTIME-populated are volumed — NEVER /home/coder/
  // .rustup or /home/coder/.cargo/bin: the rustup toolchain + cargo utilities are BAKED and must
  // track the image so an image refresh (FR-013) delivers updated tools; a persistent volume there
  // would shadow the refreshed toolchain with a stale copy (research D3 correction, verified via a
  // Docker copy-up experiment 2026-07-12). The mount-target dirs are pre-created + chowned to coder
  // in toolchain.Dockerfile so copy-up carries uid-1001 ownership into a fresh volume.
  "mounts": [
    "source=mcm-commandhistory,target=/commandhistory,type=volume",
    "source=mcm-cargo-registry,target=/home/coder/.cargo/registry,type=volume",
    "source=mcm-cargo-git,target=/home/coder/.cargo/git,type=volume",
    "source=mcm-uv-cache,target=/home/coder/.cache/uv,type=volume",
    "source=mcm-pnpm-store,target=/home/coder/.local/share/pnpm/store,type=volume",
    // 038 US3 — the PERSONAL persistence volume: plugins/skills, the RTK binary (installed here by
    // the out-of-repo dotfiles install.sh via `cargo install --root ~/.claude/tools`), and service
    // logins survive recreation (FR-007). This is the ONLY personal surface, and it is a volume —
    // no personal tool/credential is baked in the committed image (FR-009/FR-010). Empty when the
    // developer has configured no dotfiles; the container is still fully team-capable (FR-014).
    "source=mcm-claude,target=/home/coder/.claude,type=volume"
  ],

  // FR-012 — in-container marker asserted by verify/verify-host-isolation.sh.
  "containerEnv": {
    "MCM_DEVCONTAINER": "1",
    // FR-004 — point the in-container (DinD) docker CLI at its OWN config dir. The VS Code Dev
    // Containers extension writes `"credsStore": "dev-containers-<id>"` into ~/.docker/config.json,
    // but that credential helper is a HOST-side binary, absent in the container — so the nested
    // `docker pull` fails with `error getting credentials - err: exit status 255`. Overriding
    // DOCKER_CONFIG to a clean dir (created in the Dockerfile) makes the inner docker ignore that
    // helper (public/forge image pulls need no host cred forwarding here). VS Code's own ~/.docker
    // is untouched. See docs/runbooks/devcontainer.md.
    "DOCKER_CONFIG": "/home/coder/.docker-dind",
    // 038 — the forge registry / git host, so init-firewall.sh auto-allowlists it on every start
    // (default-deny otherwise blocks git pull/push to the tailnet forge). Sourced from the HOST env
    // via ${localEnv} so the topology-sensitive host literal NEVER enters git (topology-scrub) — set
    // `FORGE_REGISTRY_HOST` on the host (setx) exactly like MCM_DEVCONTAINER_IMAGE. Unset → empty →
    // init-firewall skips it cleanly (no forge access, but the container still comes up).
    "FORGE_REGISTRY_HOST": "${localEnv:FORGE_REGISTRY_HOST}",
    // Anthropic API key for the movie-assistant agent's model backend and the golden cassette
    // RE-RECORD path (golden's surface is Claude — claude-haiku-4-5 / claude-sonnet-4-6 — so record
    // mode makes real Anthropic calls; replay mode is keyless). Ollama is unreachable from the
    // containerized gateway (the nested-DinD `host.docker.internal` resolves to this container, not the
    // Windows host), so Anthropic is the in-container model path; api.anthropic.com is already in the
    // init-firewall allowlist. Sourced from the HOST env via ${localEnv} so no key literal enters git
    // (secret-scan). This is a real `sk-ant-...` API key (pay-per-token) — SEPARATE from a Claude Code
    // subscription login. Set it on the host (setx ANTHROPIC_API_KEY ...); unset → empty → the agent
    // falls back to its default (ollama) and golden record is unavailable, but the container still comes up.
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    // TMDB v3 API key for the movie-assistant agent's TMDB enrichment/search (web-api-mcp) and the
    // agent web E2E: the assistant dock only renders once the test user has a RUNNABLE agent config,
    // and agent-config-seed.ts requires a TMDB key (`SEED_TMDB_KEY = process.env.TMDB_API_KEY`) to seed
    // one — so US1-navigate / US4-add-from-TMDB agent flows need it. TMDB egress itself is NOT
    // firewall-blocked (web-api-mcp is a nested container → FORWARD chain, not the dev-container OUTPUT
    // allowlist). Free v3 key from themoviedb.org → Settings → API. Sourced from the HOST env via
    // ${localEnv} so no key literal enters git (secret-scan). Unset → empty → the agent's TMDB flows
    // no-op and the dock stays hidden, but the container still comes up. Run gen-dev-env.mjs after
    // rebuild to also write it into mcp-servers/web-api-mcp/.env.local.
    "TMDB_API_KEY": "${localEnv:TMDB_API_KEY}",
    // Read-only Forgejo token for CI self-serve diagnostics (PRD-CISelfServeDiagnostics.md §3.4).
    // Scopes: read:repository + read:issue + read:package. It is deliberately NOT the credential
    // `git credential fill` returns — that one is write-capable yet repository-scoped ONLY (403 on
    // issues/{n}/comments, 401 reqPackageAccess on the package registry), so it cannot read the
    // failure digest or bundle. This token is strictly less privilege (read-only) but reaches those
    // endpoints. Sourced from the HOST env via ${localEnv} so no token literal enters git
    // (secret-scan). Set it on the host (setx MCM_FORGE_TOKEN ...) exactly like ANTHROPIC_API_KEY;
    // unset → empty → CI diagnostics tooling reports the missing scope and exits, but the container
    // still comes up.
    "MCM_FORGE_TOKEN": "${localEnv:MCM_FORGE_TOKEN}"
  },

  // FR-005 / US3 — forward this project's REAL dev ports so a browser or a physical device on
  // the LAN reaches a dev server running inside the container. Verified against the codebase:
  //   8081  Metro dev server (also serves the Expo Router web target + dev BFF API routes)
  //   8082  containerized dev BFF (E2E_BFF_TARGET=dev-container)
  //   8099  Keycloak (browser OAuth redirect on web login)
  // The legacy Expo 19000/19001/19006 ports are NOT used by this Expo SDK 56 project.
  "forwardPorts": [8081, 8082, 8099],
  "portsAttributes": {
    "8081": { "label": "Metro / Expo Web / dev BFF", "onAutoForward": "notify" },
    "8082": { "label": "Containerized dev BFF", "onAutoForward": "silent" },
    "8099": { "label": "Keycloak (OAuth)", "onAutoForward": "silent" }
  },

  "customizations": {
    "vscode": {
      // G4 — Linux line endings inside the container.
      "settings": {
        "files.eol": "\n"
      },
      "extensions": [
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },

  // No secrets (FR-010). corepack + Claude Code CLI are baked in the image (root-level, see
  // Dockerfile); postCreate only installs workspace deps as `coder`. On the named-volume path
  // (fresh clone) this is a clean install. `--config.confirmModulesPurge=false` prevents a
  // non-interactive abort (ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY) IF the workspace already
  // carries an incompatible node_modules — which only happens on the bind-mount path (a
  // Windows checkout); see the runbook's node_modules caveat.
  // 038 US2 (T018) — belt-and-suspenders ownership repair. The image pre-chowns the cache-dir
  // targets so copy-up carries uid 1001 into a FRESH volume, but a volume created root-owned by a
  // prior/aborted run would deny `coder` its first write. onCreateCommand runs once at creation as
  // `coder` (NOPASSWD sudo) and repairs ownership before postCreate's pnpm install touches the
  // pnpm store. `|| true` so it never blocks start (FR-014).
  "onCreateCommand": "sudo chown -R coder:coder /home/coder/.cargo /home/coder/.cache/uv /home/coder/.local/share/pnpm /home/coder/.claude || true",

  "postCreateCommand": "pnpm install --config.confirmModulesPurge=false",

  // Apply the default-deny egress firewall on EVERY start (ipset is not persisted). Runs as
  // root via passwordless sudo, then the session drops back to `coder` (research D4, FR-002).
  // Placed after DinD's dockerd is up (US2) so it does not clobber docker's own chains.
  // `sudo env FORGE_REGISTRY_HOST=…` explicitly forwards the var THROUGH sudo — sudo resets the
  // environment by default, so a plain `sudo bash init-firewall.sh` would NOT see FORGE_REGISTRY_HOST
  // (from containerEnv) and would skip the forge allowlist. The outer shell expands the value from
  // the container env (containerEnv above); if unset it is empty and init-firewall skips cleanly.
  "postStartCommand": "sudo env FORGE_REGISTRY_HOST=$FORGE_REGISTRY_HOST /bin/bash ${containerWorkspaceFolder}/.devcontainer/init-firewall.sh && /bin/bash ${containerWorkspaceFolder}/scripts/devcontainer-ollama.sh"
}
