# Environment variable documentation
# Copy this file to .env.local and fill in values

# Keycloak
KEYCLOAK_URL=http://localhost:8080
# Native Keycloak URL — Android emulator: http://10.0.2.2:8099 / physical device: http://<LAN-IP>:8099
EXPO_PUBLIC_KEYCLOAK_NATIVE_URL=http://10.0.2.2:8099
KEYCLOAK_REALM=jumbleknot
KEYCLOAK_CLIENT_ID=movie-collection-manager
KEYCLOAK_CLIENT_SECRET=<your-client-secret>

# Keycloak service account for Admin API calls (see quickstart.md §2h)
KEYCLOAK_SERVICE_CLIENT_ID=mcm-bff-service
KEYCLOAK_SERVICE_CLIENT_SECRET=<copy-from-keycloak-clients-mcm-bff-service-credentials>

# Redis
REDIS_URL=redis://localhost:6379

# Cookie signing secret (min 32 chars)
COOKIE_SECRET=<generate-with: openssl rand -hex 32>

# Session config (milliseconds)
SESSION_IDLE_TIMEOUT_MS=1800000
SESSION_ABSOLUTE_TIMEOUT_MS=86400000
MAX_CONCURRENT_SESSIONS=10

# Expo public vars (available on client)
EXPO_PUBLIC_BFF_BASE_URL=http://localhost:8081
# Native BFF URL — Android emulator: http://10.0.2.2:8081 / physical device: http://<LAN-IP>:8081
EXPO_PUBLIC_BFF_NATIVE_URL=http://10.0.2.2:8081

# mc-service (local dev — BFF proxies to mc-service on this URL)
# For Docker deployment, set MC_SERVICE_URL=http://mc-service:3001 in .env.docker
MC_SERVICE_URL=http://localhost:3001

# Agent Gateway (feature 012). Unset on Metro → run+api.ts uses the loopback
# http://127.0.0.1:8123 (the gateway's profile-gated host port). The container BFF sets
# the internal DNS URL in .env.docker instead.
# AGENT_GATEWAY_URL=http://127.0.0.1:8123

# Agent subject-token mint (feature 012 T023 — RFC 8693). Leave the secret EMPTY to
# DISABLE minting — the tool-free graph runs without it; US1 tool calls require it once
# Keycloak standard token exchange (T012) is configured.
# AGENT_SUBJECT_TOKEN_CLIENT_ID=agent-subject-token
# AGENT_SUBJECT_TOKEN_CLIENT_SECRET=
# AGENT_SUBJECT_TOKEN_AUDIENCE=agent-gateway

# Agent assistant rate / cost limits (feature 012 T027 — FR-020a / SC-011). Per-user
# request rate limit + per-user/session cost ceiling (USD; per-turn cost from LangFuse,
# T030). Breach → friendly "try again later", no action. Defaults shown; uncomment to override.
# AGENT_RATE_LIMIT_REQUESTS=20
# AGENT_RATE_LIMIT_WINDOW_MS=60000
# AGENT_SESSION_COST_CEILING_USD=0.50
# Estimated per-turn cost accrued against the ceiling on each billable /run turn — makes the
# cost ceiling enforceable in the default config (the real per-turn figure is observability-gated).
# Ceiling / estimate = turns per session (0.50 / 0.01 = 50). Tune to your models' observed cost.
# AGENT_ESTIMATED_TURN_COST_USD=0.01

# Control Tower — OPA + OpenSearch (all OPTIONAL — unset = no-op; SC-005 additive)
# OPA (ui-action authz via Rego). Stack: docker compose --profile observability up -d.
# Unset = BFF ui-action authz falls back to the TS authorizer.
# OPA_URL=http://localhost:8181

# OpenSearch (append-only agent audit sink). Stack: docker compose --profile audit up -d.
# First-time: docker volume create opensearch-data, then run init-audit-user.sh.
# Heap pinned to 1 GB in compose (OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g) — prevents 4 GB-default OOM.
# Write-only sink user: agent-audit (cannot read/delete). Unset = audit events logged only.
# OPENSEARCH_URL=https://localhost:9200
# OPENSEARCH_USERNAME=agent-audit
# OPENSEARCH_PASSWORD=Mcm-dev-AuditWriter-1!
