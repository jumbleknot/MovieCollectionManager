{
  "name": "mcm-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:integration": "jest --testPathPattern=tests/integration --watchAll=false",
    "test:e2e:mobile": "maestro test tests/e2e/mobile/",
    "test:e2e:web": "npx nx e2e",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.53",
    "@ai-sdk/openai": "^3.0.68",
    "@copilotkit/react-native": "^1.59.5",
    "@copilotkit/runtime": "1.59.5",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/outfit": "^0.2.3",
    "@expo/metro-runtime": "^56.0.13",
    "@expo/server": "~0.5.0",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@mcm/design-system": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-picker/picker": "^2.11.4",
    "@tamagui/config": "^2.3.0",
    "@tamagui/core": "^2.3.0",
    "@tamagui/stacks": "^2.3.0",
    "axios": "^1.7.9",
    "expo": "^56.0.8",
    "expo-auth-session": "~56.0.13",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.6",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "express": "^4.21.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.42.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-streamdown": "^0.2.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3",
    "tamagui": "^2.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@playwright/test": "^1.59.1",
    "@tamagui/babel-plugin": "^2.3.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/react": "~19.2.0",
    "axios-mock-adapter": "^2.1.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~56.0.14",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "verbose": false,
    "setupFilesAfterEnv": [
      "<rootDir>/tests/jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/\\.pnpm/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?|@expo-google-fonts|react-navigation|@react-navigation|@unimodules|unimodules|sentry-expo|native-base|react-native-svg|@copilotkit|@ag-ui|uuid|tamagui|@tamagui)[^/]*/node_modules)",
      "node_modules/(?!(\\.pnpm|(jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?|@expo-google-fonts|react-navigation|@react-navigation|@unimodules|unimodules|sentry-expo|native-base|react-native-svg|@copilotkit|@ag-ui|uuid|tamagui|@tamagui))"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/",
      "/tests/load/",
      "/tests/web-e2e/",
      "/tests/integration/"
    ],
    "moduleNameMapper": {
      "^expo-router/server$": "<rootDir>/__mocks__/expo-router-server.js",
      "^@react-native-picker/picker$": "<rootDir>/__mocks__/@react-native-picker/picker.js"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/__mocks__/**"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  },
  "overrides": {
    "react-dom": "19.2.3",
    "postcss": ">=8.5.10"
  },
  "private": true,
  "packageManager": "pnpm@10.33.0"
}
