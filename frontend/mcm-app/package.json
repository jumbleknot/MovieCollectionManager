{
  "name": "mcm-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:integration": "jest --testPathPattern=tests/integration --watchAll=false",
    "test:e2e:mobile": "maestro test tests/e2e/mobile/",
    "test:e2e:web": "npx nx e2e",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.11",
    "@expo/server": "~0.5.0",
    "@react-native-picker/picker": "^2.11.4",
    "axios": "^1.7.9",
    "expo": "^55.0.0",
    "expo-auth-session": "~55.0.15",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.6",
    "expo-web-browser": "~55.0.15",
    "express": "^4.21.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/react-native": "^13.2.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/react": "~19.2.0",
    "axios-mock-adapter": "^2.1.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~55.0.21",
    "eas-cli": "latest",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~55.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.17",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/\\.pnpm/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?|@expo-google-fonts|react-navigation|@react-navigation|@unimodules|unimodules|sentry-expo|native-base|react-native-svg)[^/]*/node_modules)",
      "node_modules/(?!(\\.pnpm|(jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?|@expo-google-fonts|react-navigation|@react-navigation|@unimodules|unimodules|sentry-expo|native-base|react-native-svg))"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/",
      "/tests/load/",
      "/tests/web-e2e/"
    ],
    "moduleNameMapper": {
      "^expo-router/server$": "<rootDir>/__mocks__/expo-router-server.js",
      "^@react-native-picker/picker$": "<rootDir>/__mocks__/@react-native-picker/picker.js"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/__mocks__/**"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  },
  "overrides": {
    "react-dom": "19.2.0",
    "postcss": ">=8.5.10"
  },
  "private": true,
  "packageManager": "pnpm@10.33.0"
}
