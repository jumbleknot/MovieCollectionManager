{
  "name": "mcm-app",
  "projectType": "application",
  "root": "frontend/mcm-app",
  "sourceRoot": "frontend/mcm-app/src",
  "tags": ["scope:frontend", "type:app", "platform:mobile", "platform:web"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "jest --watchAll=false",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["default", "^default"]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "jest --testPathPattern=tests/integration --watchAll=false",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint src --ext .ts,.tsx",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["default"]
    },
    "e2e:mobile": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/maestro-e2e.mjs",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "e2e:mobile:session-timeout": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/maestro-session-timeout.mjs",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t mcm-bff:latest -f frontend/mcm-app/Dockerfile .",
        "cwd": "{workspaceRoot}"
      },
      "cache": false
    },
    "start-keycloak": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f infrastructure-as-code/docker/keycloak/compose.yaml up -d",
        "cwd": "{workspaceRoot}"
      },
      "cache": false
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f infrastructure-as-code/docker/bff/compose.yaml up -d",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["build", "start-keycloak"],
      "cache": false
    },
    "eas-build-local": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eas build --local --platform android --profile development",
        "cwd": "{projectRoot}"
      }
    },
    "export-server": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx expo export --platform web",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t mcm-bff:latest -f frontend/mcm-app/Dockerfile .",
        "cwd": "{workspaceRoot}"
      }
    },
    "docker-up": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f infrastructure-as-code/docker/bff/compose.yaml up -d",
        "cwd": "{workspaceRoot}"
      }
    },
    "docker-down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f infrastructure-as-code/docker/bff/compose.yaml down",
        "cwd": "{workspaceRoot}"
      }
    },
    "test:load": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tests/load/run.js",
        "cwd": "{projectRoot}"
      },
      "cache": false
    }
  }
}
