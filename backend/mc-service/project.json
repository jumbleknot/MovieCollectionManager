{
  "name": "mc-service",
  "projectType": "application",
  "root": "backend/mc-service",
  "sourceRoot": "backend/mc-service/src",
  "tags": ["scope:backend", "type:app", "platform:docker"],
  "targets": {
    "test": {
      "executor": "@monodon/rust:test",
      "options": {},
      "cache": true,
      "inputs": ["default", "^default"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test --manifest-path backend/mc-service/Cargo.toml -p mc-service --lib",
        "cwd": "{workspaceRoot}"
      },
      "cache": true,
      "inputs": ["default"]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test --manifest-path backend/mc-service/Cargo.toml --tests -- --test-threads=1",
        "cwd": "{workspaceRoot}"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy --manifest-path backend/mc-service/Cargo.toml -p mc-service -- -D warnings",
        "cwd": "{workspaceRoot}"
      },
      "cache": true,
      "inputs": ["default"]
    },
    "serve": {
      "executor": "@monodon/rust:run",
      "options": {},
      "cache": false
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t mc-service:latest -f backend/mc-service/Dockerfile .",
        "cwd": "{workspaceRoot}"
      },
      "cache": false
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f infrastructure-as-code/docker/mc-service/compose.yaml up -d",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["build"],
      "cache": false
    },
    "docker-down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f infrastructure-as-code/docker/mc-service/compose.yaml down",
        "cwd": "{workspaceRoot}"
      },
      "cache": false
    }
  }
}
