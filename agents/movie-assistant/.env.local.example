# movie-assistant (Agent Gateway) local config — copy to .env.local and fill in.
# No inline comments on value lines (dotenv loaders capture them literally).

# --- Model provider (research R1) ---
# Default Ollama in every environment; switch to anthropic as the documented fallback.
MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
SUPERVISOR_MODEL=qwen2.5
SPECIALIST_MODEL=qwen2.5:32b
ESCALATION_MODEL=claude-opus-4-8
# Only required when MODEL_PROVIDER=anthropic (or escalation flag active):
ANTHROPIC_API_KEY=

# --- Agent state (isolated) ---
AGENT_DB_URL=postgresql://agent:agent@localhost:5433/agent_db

# --- Identity / token exchange (research R3) ---
KEYCLOAK_URL=http://keycloak-service:8080
KEYCLOAK_REALM=jumbleknot
AGENT_GATEWAY_CLIENT_ID=agent-gateway
AGENT_GATEWAY_CLIENT_SECRET=

# --- Per-agent tool-call rate limit (T027a, constitution per-agent limit) ---
# Caps each specialist's tool calls per sliding window; breach degrades gracefully.
AGENT_TOOL_CALL_LIMIT=30
AGENT_TOOL_CALL_WINDOW_SECONDS=60

# --- Control Tower (all OPTIONAL — unset = no-op; SC-005 additive) ---
# LangFuse (LLM cost/latency traces, SC-008). Stack: docker compose --profile observability up -d
# The --profile observability LangFuse v3 self-host bootstraps these deterministic dev keys:
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=pk-lf-mcm-dev-0000000000000000
LANGFUSE_SECRET_KEY=sk-lf-mcm-dev-0000000000000000

# Per-turn budgets (SC-008): a breach is surfaced (WARN + trace tag), non-blocking.
AGENT_PER_TURN_COST_BUDGET_USD=0.05
AGENT_TURN_LATENCY_BUDGET_MS=20000

# Error-rate circuit breaker (T030): opens → graceful-degradation reply, half-open after cooldown.
AGENT_ERROR_RATE_THRESHOLD=0.5
AGENT_ERROR_RATE_WINDOW=20
AGENT_ERROR_RATE_COOLDOWN_S=30
AGENT_ERROR_RATE_MIN_SAMPLES=5

# OpenTelemetry infra traces → otel-lgtm (Tempo/Prometheus/Loki/Grafana). Unset = no export.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=movie-assistant-gateway

# HashiCorp Vault runtime secret injection (T030a). Unset = use the env values directly.
# When set, ANTHROPIC_API_KEY / AGENT_GATEWAY_CLIENT_SECRET are read from Vault (secret/movie-assistant).
VAULT_ADDR=
VAULT_TOKEN=

# OPA (agent authz — token-exchange + ui-action via Rego). Stack: --profile observability.
# Unset = gateway token-exchange authz and BFF ui-action authz fall back to allow / TS authorizer.
# OPA_URL=http://opa:8181

# Unleash (feature flags: kill-switch / frontier-escalation / degrade). Stack: --profile observability.
# Flags default-off. SDK URL = base + /api (e.g. http://localhost:4242/api).
# Unset = falls back to env flags (AGENT_KILL_SWITCH, etc.) — no-op by default.
# UNLEASH_URL=http://localhost:4242/api
# Dev client token (do not use in production):
# UNLEASH_API_TOKEN=default:development.mcm-dev-unleash-client-token

# OpenSearch (append-only agent audit sink). Stack: --profile audit (NOT --profile observability).
# First-time: docker volume create opensearch-data, then run init-audit-user.sh.
# Heap pinned to 1 GB (OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g) in compose to avoid the 4 GB-default OOM.
# Write-only sink user: agent-audit / Mcm-dev-AuditWriter-1! (cannot read/delete).
# Unset = audit events are logged only (no OpenSearch write) — no-op by default.
# OPENSEARCH_URL=https://localhost:9200
# OPENSEARCH_USERNAME=agent-audit
# OPENSEARCH_PASSWORD=Mcm-dev-AuditWriter-1!
