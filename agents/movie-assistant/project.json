{
  "name": "movie-assistant",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "agents/movie-assistant/src",
  "targets": {
    "lock": {
      "executor": "@nxlv/python:run-commands",
      "options": { "command": "uv lock", "cwd": "agents/movie-assistant" }
    },
    "install": {
      "executor": "@nxlv/python:install",
      "options": {}
    },
    "lint": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run ruff check . && uv run mypy src",
        "cwd": "agents/movie-assistant"
      }
    },
    "test": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run pytest tests/unit",
        "cwd": "agents/movie-assistant"
      }
    },
    "test:integration": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "uv run pytest tests/integration",
        "cwd": "agents/movie-assistant"
      }
    },
    "build": {
      "executor": "@nxlv/python:run-commands",
      "options": {
        "command": "docker build -f agents/movie-assistant/Dockerfile -t agent-gateway:latest .",
        "cwd": "."
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose --profile agents up -d",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tags": ["layer:agents", "lang:python"]
}
