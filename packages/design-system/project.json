{
  "name": "design-system",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "packages/design-system",
  "sourceRoot": "packages/design-system",
  "tags": ["scope:design-system", "type:lib", "platform:web", "platform:mobile"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "jest --watchAll=false",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["default", "^default"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint . --ext .ts,.tsx",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["default"]
    }
  }
}
