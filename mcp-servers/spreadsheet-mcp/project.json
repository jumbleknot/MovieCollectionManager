{
  "name": "spreadsheet-mcp",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "mcp-servers/spreadsheet-mcp/src",
  "targets": {
    "lock": {
      "executor": "@nxlv/python:run-commands",
      "options": { "command": "uv lock", "cwd": "mcp-servers/spreadsheet-mcp" }
    },
    "lint": {
      "executor": "@nxlv/python:run-commands",
      "options": { "command": "uv run ruff check . && uv run mypy src", "cwd": "mcp-servers/spreadsheet-mcp" }
    },
    "test": {
      "executor": "@nxlv/python:run-commands",
      "options": { "command": "uv run pytest tests/unit", "cwd": "mcp-servers/spreadsheet-mcp" }
    },
    "test:integration": {
      "executor": "@nxlv/python:run-commands",
      "options": { "command": "uv run pytest tests/integration", "cwd": "mcp-servers/spreadsheet-mcp" }
    },
    "build": {
      "executor": "@nxlv/python:run-commands",
      "options": { "command": "docker build -f mcp-servers/spreadsheet-mcp/Dockerfile -t spreadsheet-mcp:latest .", "cwd": "." }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": { "command": "docker compose --profile agents up -d spreadsheet-mcp", "cwd": "{workspaceRoot}" }
    }
  },
  "tags": ["layer:mcp", "lang:python"]
}
