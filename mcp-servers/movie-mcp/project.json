{
  "name": "movie-mcp",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "mcp-servers/movie-mcp/src",
  "targets": {
    "lock": {
      "executor": "@nxlv/python:run-commands",
      "options": { "command": "uv lock", "cwd": "mcp-servers/movie-mcp" }
    },
    "lint": {
      "executor": "@nxlv/python:run-commands",
      "options": { "command": "uv run ruff check . && uv run mypy src", "cwd": "mcp-servers/movie-mcp" }
    },
    "test": {
      "executor": "@nxlv/python:run-commands",
      "options": { "command": "uv run pytest tests/unit", "cwd": "mcp-servers/movie-mcp" }
    },
    "test:integration": {
      "executor": "@nxlv/python:run-commands",
      "options": { "command": "uv run pytest tests/integration", "cwd": "mcp-servers/movie-mcp" }
    },
    "build": {
      "executor": "@nxlv/python:run-commands",
      "options": { "command": "docker build -f mcp-servers/movie-mcp/Dockerfile -t movie-mcp:latest .", "cwd": "." }
    }
  },
  "tags": ["layer:mcp", "lang:python"]
}
