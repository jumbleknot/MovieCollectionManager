{
  "name": "infrastructure-as-code",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "up-test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose up -d",
        "cwd": "{workspaceRoot}"
      }
    },
    "up-app": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose up -d --profile app",
        "cwd": "{workspaceRoot}"
      }
    },
    "up-keycloak": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose up -d --profile keycloak",
        "cwd": "{workspaceRoot}"
      }
    },
    "up-all": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose up -d --profile app --profile keycloak",
        "cwd": "{workspaceRoot}"
      }
    },
    "down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose down",
        "cwd": "{workspaceRoot}"
      }
    },
    "down-all": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose down --volumes",
        "cwd": "{workspaceRoot}"
      }
    },
    "ps": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose ps",
        "cwd": "{workspaceRoot}"
      }
    },
    "up-agents-prod": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/agent-stack.mjs",
        "cwd": "{workspaceRoot}"
      },
      "metadata": {
        "description": "Deploy the containerized production-node agent stack (gateway + movie-mcp + web-api-mcp; host Ollama, MemorySaver) for local agent E2E. Pass --args=--build to force-rebuild images."
      }
    },
    "down-agents-prod": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/agent-stack.mjs --down",
        "cwd": "{workspaceRoot}"
      },
      "metadata": {
        "description": "Remove the containerized production-node agent stack (gateway + movie-mcp + web-api-mcp)."
      }
    },
    "status-agents-prod": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/agent-stack.mjs --status",
        "cwd": "{workspaceRoot}"
      }
    },
    "check-naming": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/check-resource-naming.mjs",
        "cwd": "{workspaceRoot}"
      },
      "metadata": {
        "description": "Static resource-naming gate (feature 019): assert every Docker volume/network/container_name follows the convention. Pass --args=--section=volumes|networks|containers|ollama|all (default all)."
      }
    }
  }
}
