# Production agent stack (prod-movie-assistant) secrets/values — feature 023 Milestone B.
#
# COMMITTED template (placeholders only — .gitignore negates *.env.prod.example). On the PROD host /
# in the Komodo Stack Environment:
#   cp .env.prod.example .env.prod && chmod 600 .env.prod   # the real .env.prod is gitignored
# NEVER commit real values. Non-secret config (MODEL_PROVIDER, KEYCLOAK_URL/REALM, *_MCP_URL, AGENT_DB_URL)
# is inline in compose.prod.yaml and NOT repeated here.

# Registry host (R10, host-free digest). The compose assembles each image as
#   ${REGISTRY_HOST}/jumbleknot/<svc>@${<SVC>_DIGEST}
# with the *_DIGEST from the committed .env.deploy (cd-deploy promotion). Keep the host OUT of git.
# e.g. <tailnet-host>:3000
REGISTRY_HOST=<registry-host:port>

# ── Mandatory secrets (fail-fast ${VAR:?} in compose.prod.yaml) ───────────────────────────────────
# LangGraph checkpointer Postgres password (also initialises movie-assistant-store-postgres).
AGENT_DB_PASSWORD=<agent-db password>
# Confidential 'agent-gateway' client secret — RFC 8693 token re-exchange (aud=mc-service). MANDATORY:
# an empty value is fail-CLOSED (token exchange skipped → every MCP tool call fails). Copy from the
# Keycloak admin console (clients → agent-gateway → Credentials) after the prod realm import.
AGENT_GATEWAY_CLIENT_SECRET=<agent-gateway client secret>

# ── Optional (env_file-injected, may be empty) ────────────────────────────────────────────────────
# Shared Anthropic key. Feature 018 uses PER-USER BYO keys (injected per-run via X-Agent-Config); the
# gateway pops any shared key for users without their own, so this is normally LEFT EMPTY. Set it only
# if you intend a shared org key as a default (discouraged — it would be spent on org credit).
ANTHROPIC_API_KEY=

# Note: the *_DIGEST image pins come from the committed .env.deploy (cd-deploy rewrites it), loaded as
# an Additional Env File — NOT here. Only REGISTRY_HOST + the secrets above live in this file.
# Reminder: deploying this stack also requires AGENT_SUBJECT_TOKEN_CLIENT_SECRET set in bff/.env.prod
# (the BFF mints the run-scoped subject token the gateway re-exchanges).
