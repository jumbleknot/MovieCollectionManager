# Production Keycloak secrets/values — feature 022/023 (prod-auth Komodo Stack).
#
# This template is COMMITTED (placeholders only). On the PROD host, copy it next to
# compose.prod.yaml and fill real values:
#   cp .env.prod.example .env.prod && chmod 600 .env.prod
# The real `.env.prod` is gitignored (the *.env.* rule). NEVER commit real values.

# Public base domain (also set as the Komodo Stack env / Forgejo BASE_DOMAIN var). e.g. example.com
BASE_DOMAIN=<your-public-base-domain>

# (feature 028) KC_ADMIN_BIND_IP removed — the admin port now binds 0.0.0.0 (a tailnet-IP bind fails the
# rootless-before-tailscaled boot race); tailnet-only exposure is kept by the host ufw default-deny.

# Tailnet URL for the Keycloak admin console (not the public host). e.g. http://prod-host.tailnet.ts.net:8099
KC_HOSTNAME_ADMIN=<tailnet-admin-url>

# Keycloak bootstrap admin password (first-boot admin user).
KC_BOOTSTRAP_ADMIN_PASSWORD=<your-prod-keycloak-admin-password>

# Keycloak→Postgres DB password (feature 022): single source of truth — both the postgres service
# and keycloak-service interpolate this one var. No secrets/*.txt file. On a FRESH DB volume any
# value works; an existing volume keeps its original password.
KC_DB_PASSWORD=<your-prod-keycloak-db-password>

# Absolute path to the RENDERED realm file mounted for --import-realm. The committed
# prod-realm.json keeps the ${BASE_DOMAIN} placeholder; render it at deploy (envsubst
# RESTRICTED to BASE_DOMAIN — the realm JSON also contains Keycloak ${role_*}/${client_*}
# i18n placeholders that must be left intact) into a gitignored file, then point here:
#   envsubst '${BASE_DOMAIN}' < prod-realm.json > prod-realm.rendered.json
PROD_REALM_FILE=<abs-path-to>/prod-realm.rendered.json
