# Production BFF (prod-mcm-bff) secrets/values — feature 022/023.
#
# This template is COMMITTED (placeholders only — see .gitignore negation
# `!infrastructure-as-code/docker/**/*.env.prod.example`). On the PROD host:
#   cp .env.prod.example .env.prod && chmod 600 .env.prod   # the real .env.prod is gitignored
# NEVER commit real values.
#
# Non-secret operational config (KEYCLOAK_URL, KEYCLOAK_REALM, REDIS_URL, session timeouts, …) is set
# inline in compose.prod.yaml and is NOT repeated here. This file supplies only the deploy-specific
# host var, the mandatory secrets (consumed as ${VAR:?} fail-fast refs in the compose), and the one
# optional agent secret. Keys mirror what the BFF reads (config/env.ts).

# Public base domain (also the Komodo Stack env / Forgejo BASE_DOMAIN var). e.g. example.com
# Feeds KEYCLOAK_PUBLIC_URL=https://auth.${BASE_DOMAIN} and the app origin mcm.${BASE_DOMAIN}.
BASE_DOMAIN=<your-public-base-domain>

# Registry host (R10, host-free digest). The compose assembles the image as
#   ${REGISTRY_HOST}/jumbleknot/mcm-bff@${MCM_BFF_DIGEST}
# with MCM_BFF_DIGEST coming from the committed .env.deploy (cd-deploy promotion). Keep the host OUT of
# git — supply it here / as a Komodo Variable. e.g. <tailnet-host>:3000
REGISTRY_HOST=<registry-host:port>

# ── Mandatory secrets (fail-fast in compose.prod.yaml) ─────────────────────────────
# Prod 'movie-collection-manager' confidential-client secret (regenerate in the Keycloak admin
# console after the realm import, then paste here).
KEYCLOAK_CLIENT_SECRET=<prod movie-collection-manager client secret>
# Prod 'mcm-bff-service' service-account client secret (Admin API: user lookup, SSO logout, etc.).
KEYCLOAK_SERVICE_CLIENT_SECRET=<prod mcm-bff-service client secret>
# Cookie signing secret — min 32 random chars. e.g. `node -e "console.log(crypto.randomBytes(32).toString('hex'))"`
COOKIE_SECRET=<min-32-char-random-hex>
# AES-256-GCM master key for the per-user agent config store (feature 018). MUST be the BASE64 of 32
# random bytes (agent-config-crypto.ts loads it as base64 and requires exactly 32 bytes). Generate with
#   openssl rand -base64 32          # → 44 chars ending in '=', e.g. 8Kk9…=
# NOT hex — a 64-char hex value decodes as base64 to ~48 bytes and the config save fails with 500.
AGENT_CONFIG_ENC_KEY=<base64 of 32 random bytes — `openssl rand -base64 32`>

# ── Optional (env_file-injected, may be empty) ─────────────────────────────────────
# Subject-token mint secret (RFC 8693). LEAVE EMPTY to DISABLE minting until prod-agents is deployed
# (the tool-free graph still runs). The matching client_id/audience are non-secret and set in compose.
AGENT_SUBJECT_TOKEN_CLIENT_SECRET=

# Note: MCM_BFF_DIGEST (the bare sha256 image digest) is supplied by the committed .env.deploy that
# cd-deploy rewrites every run (loaded as an Additional Env File) — NOT here. Only REGISTRY_HOST (above)
# lives in this file; the host + digest combine in compose.prod.yaml.
