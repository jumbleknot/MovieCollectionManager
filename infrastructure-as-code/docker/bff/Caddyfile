# Feature 007 (US3) — TLS-terminating reverse proxy for the PROD BFF container.
#
# Terminates HTTPS on :8443 with Caddy's internal CA (local-only; no ACME) and
# proxies to the NODE_ENV=production mcm-bff-service-secure over the internal Docker network.
# This is the no-weakening way to satisfy Secure cookies (FR-007): the browser
# talks HTTPS to Caddy, so Secure/HttpOnly/SameSite cookies flow normally, while
# the BFF keeps NODE_ENV=production (Secure cookies) end to end.
#
# Web E2E trusts the internal CA via Playwright `ignoreHTTPSErrors`; the emulator
# needs the CA installed (see quickstart §2 / research R3).

{
	# Local-only TLS: no ACME, no HTTP->HTTPS redirect vhost (only :8443 is mapped).
	auto_https disable_redirects
	admin off
}

localhost:8443 {
	# Internal CA issues the localhost leaf cert. Constitution Transport Security:
	# enforce TLS 1.3 as the minimum negotiated version.
	tls internal {
		protocols tls1.3
	}

	# HSTS is owned by the HTTPS edge (the BFF runs plain HTTP internally, so it
	# must not — and does not — set HSTS itself).
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# The BFF's own security headers (Content-Security-Policy, X-Frame-Options,
	# X-Content-Type-Options, Referrer-Policy), the X-BFF-Source marker, CORS, and
	# all Set-Cookie headers are emitted by the upstream and passed through unchanged
	# by reverse_proxy.
	reverse_proxy mcm-bff-service-secure:3000
}
