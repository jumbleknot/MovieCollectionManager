# mcm stack secrets — feature 021 (externalize-compose-secrets).
#
# This template is COMMITTED. Real values are minted per-machine by
#   node scripts/gen-dev-secrets.mjs
# into mcm.env (gitignored). NEVER put a real value in this file.
#
# AGENT_DB_PASSWORD is URL-embedded (agent-gateway AGENT_DB_URL) → URL-safe (base62) kind.
AGENT_DB_PASSWORD=<generate:b62-32>

# Feature 026 — production MongoDB authentication. These are consumed ONLY by the prod compose files
# (mc-service/bff compose.prod.yaml) and by the scratch/rehearsal environment that mirrors prod; plain
# local dev (compose.yaml) stays UNAUTHENTICATED (FR-009), so these vars are unused there.
# complex-16 uses a URL-safe alphabet, so the app passwords embed cleanly in the Mongo connection URLs.
MONGO_MC_APP_PASSWORD=<generate:complex-16>
MONGO_MC_ROOT_PASSWORD=<generate:complex-16>
MONGO_BFF_APP_PASSWORD=<generate:complex-16>
MONGO_BFF_ROOT_PASSWORD=<generate:complex-16>
# Replica-set keyfile CONTENT (movie store only) as a single-line base64 value; materialized to an
# in-container file at start-up by mc-service/mongo-entrypoint.sh (env-only, no host file-secret).
MONGO_MC_KEYFILE=<generate:mongo-keyfile>
