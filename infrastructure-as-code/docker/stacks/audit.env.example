# audit stack secrets — feature 021 (externalize-compose-secrets).
#
# This template is COMMITTED. Real values are minted per-machine by
#   node scripts/gen-dev-secrets.mjs
# into audit.env (gitignored). NEVER put a real value in this file.
#
# OPENSEARCH_INITIAL_ADMIN_PASSWORD is used in a `-u admin:<pw>` curl arg (healthcheck),
# never in a URL → complex-16 (the charset excludes shell/URL-breaking characters).
OPENSEARCH_INITIAL_ADMIN_PASSWORD=<generate:complex-16>
# Write-only agent-audit account password — provisioned at runtime by
# opensearch/init-audit-user.sh and used by the audit integration tests (feature 022).
OPENSEARCH_AUDIT_WRITER_PASSWORD=<generate:complex-16>
