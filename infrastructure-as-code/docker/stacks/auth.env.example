# auth stack secrets — feature 021 (externalize-compose-secrets).
#
# This template is COMMITTED. Real values are minted per-machine by
#   node scripts/gen-dev-secrets.mjs
# into auth.env (gitignored). NEVER put a real value in this file.
#
# Each <generate:KIND> placeholder is replaced by a freshly-minted value of that KIND
# (see specs/021-externalize-compose-secrets/research.md R4). Fixed literals are copied verbatim.
KC_BOOTSTRAP_ADMIN_PASSWORD=<generate:complex-16>
# Keycloak→Postgres DB password. Single source of truth (feature 022): both the postgres service
# (POSTGRES_PASSWORD) and keycloak-service (KC_DB_PASSWORD) interpolate this one var — no file-secret,
# no .env.local dual-source. A fresh value works on a fresh DB volume; an EXISTING dev volume keeps
# its original password, so set this to that value (or wipe keycloak-store-postgres-data to re-init).
KC_DB_PASSWORD=<generate:complex-16>
VAULT_DEV_ROOT_TOKEN_ID=<generate:b62-48>
