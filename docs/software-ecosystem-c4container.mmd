C4Container
    title Software Ecosystem Architecture

    Person(app1_user, "App 1 User", "Accesses App 1 via web browser and mobile device")
    Person(app2_user, "App 2 User", "Accesses App 2 via web browser")

    Container_Boundary(software_ecosystem, "Software Ecosystem") {
        Container_Boundary(frontend, "Frontend Apps") {
            Container_Boundary(app1, "App 1") {
                Container_Boundary(app1_client, "App 1 Client") {
                    Container(app1_web, "Web App", "React Native Expo Client - Web", "Handles web-based UI rendering and interactions")
                    Container(app1_mobile, "Mobile App", "React Native Expo Client - Mobile", "Handles mobile UI rendering and interactions")
                }
                Container_Boundary(app1_bff, "App 1 BFF") {
                    Container(app1_bff_api, "App 1 BFF API", "React Native Expo Router API Routes in Node.js Docker Container", "A thin, secure layer that must encapsulate server-side API routes using the Backend for Frontend pattern")
                    ContainerDb(app1_bff_cache, "App 1 BFF Cache", "Redis in-memory database in Docker Container", "Caches session state for App 1 BFF")
                }
            }
            Container_Boundary(app2, "App 2") {
                Container_Boundary(app2_client, "App 2 Client") {
                    Container(app2_web, "Web App", "React Native Expo Client - Web", "Handles web-based UI rendering and interactions")
                }
                Container_Boundary(app2_bff, "App 2 BFF") {
                    Container(app2_bff_api, "App 2 BFF API", "React Native Expo Router API Routes in Node.js Docker Container", "A thin, secure layer that must encapsulate server-side API routes using the Backend for Frontend pattern")
                    ContainerDb(app2_bff_cache, "App 2 BFF Cache", "Redis in-memory database in Docker Container", "Caches session state for App 2 BFF")
                }
            }
        }

        Container_Boundary(backend, "Backend Services") {
            Container_Boundary(service1, "Service 1") {
            Container(service1_api, "Service 1 API", "Rust + Axum Microservice in Docker Container", "Handles Service 1 use cases and logic")
            ContainerDb(service1_db, "Service 1 Database", "PostgreSQL Database in Docker Container", "Stores Service 1 data")
            }
            Container_Boundary(service2, "Service 2") {
            Container(service2_api, "Service 2 API", "Rust + Axum Microservice in Docker Container", "Handles Service 2 use cases and logic")
            ContainerDb(service2_db, "Service 2 Database", "MongoDB Database in Docker Container", "Stores Service 2 data")
            }
        }
    }

    Container_Ext(keycloak, "Identity and Access Management", "Keycloak", "Manages user identities, authentication, SSO, and permissions")

    Rel_D(app1_user, app1_web, "Uses")
    Rel_D(app1_user, app1_mobile, "Uses")
    Rel_D(app2_user, app2_web, "Uses")

    Rel_D(app1_web, app1_bff_api, "Calls", "REST")
    Rel_D(app1_mobile, app1_bff_api, "Calls", "REST")
    Rel_D(app2_web, app2_bff_api, "Calls", "REST")

    Rel_L(app1_bff_api, app1_bff_cache, "Reads/Writes", "NoSQL")
    Rel_R(app2_bff_api, app2_bff_cache, "Reads/Writes", "NoSQL")

    Rel_D(app1_bff_api, service1_api, "Routes to", "REST/GraphQL")
    Rel_D(app1_bff_api, service2_api, "Routes to", "REST/GraphQL")
    Rel_D(app2_bff_api, service1_api, "Routes to", "REST/GraphQL")
    Rel_D(app2_bff_api, service2_api, "Routes to", "REST/GraphQL")

    Rel_D(service1_api, service1_db, "Reads/Writes", "SQL")
    Rel_D(service2_api, service2_db, "Reads/Writes", "NoSQL")

    Rel_R(app1_bff_api, keycloak, "Authenticates", "REST")
    Rel_R(app2_bff_api, keycloak, "Authenticates", "REST")
    Rel_R(service1_api, keycloak, "Validates token", "REST")
    Rel_R(service2_api, keycloak, "Validates token", "REST")
